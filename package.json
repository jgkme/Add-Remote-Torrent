    "copy-webpack-plugin": "^14.0.0",
    "crx3": "^2.0.0",
    "css-loader": "^7.1.4",
    "glob": "^13.0.6",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.22",
    "postcss-loader": "^8.2.1",
    "tailwindcss": "^4.3.3",
    "terser": "^5.49.0",
