    "@babel/preset-env": "^7.29.5",
    "@tailwindcss/postcss": "^4.3.0",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "crx3": "^2.0.0",
    "css-loader": "^7.1.4",
    "glob": "^13.0.6",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "tailwindcss": "^4.3.0",
    "terser": "^5.47.1",
    "terser-webpack-plugin": "^5.6.0",
